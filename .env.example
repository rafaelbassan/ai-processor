# =============================================================================
# VectoSports AI Results Server - Environment Configuration
# =============================================================================

# SERVER
# =============================================================================
# Host para o servidor (0.0.0.0 = aceita conexões de qualquer IP)
HOST=0.0.0.0

# Porta do servidor
PORT=8000

# URL base do servidor (usada para gerar URLs de upload)
# Altere para o seu domínio em produção
SERVER_BASE_URL=http://localhost:8000

# Nível de log: debug, info, warning, error
LOG_LEVEL=info


# UPLOAD
# =============================================================================
# Diretório base para armazenar uploads
# Em Docker, será /data/uploads (mapeado via volume)
# Localmente, pode ser ./uploads
UPLOAD_BASE_DIR=/data/uploads

# Dias de retenção para jobs completados/falhados
# Jobs antigos serão deletados automaticamente
JOB_RETENTION_DAYS=7


# CORS
# =============================================================================
# Origens permitidas para CORS (separadas por vírgula)
# Use "*" para permitir qualquer origem (apenas desenvolvimento!)
# Em produção, especifique os domínios
CORS_ORIGINS=*
# CORS_ORIGINS=http://localhost:3000,http://seu-dominio.com


# DOCKER
# =============================================================================
# Porta mapeada para o host (quando usando docker-compose)
SERVER_PORT=8000

# Nome da rede Docker
DOCKER_NETWORK=vectosports-network


# =============================================================================
# EXEMPLO DE PRODUÇÃO
# =============================================================================
# HOST=0.0.0.0
# PORT=8000
# SERVER_BASE_URL=https://api.seu-dominio.com
# LOG_LEVEL=warning
# UPLOAD_BASE_DIR=/var/vectosports/uploads
# JOB_RETENTION_DAYS=30
# CORS_ORIGINS=https://seu-dominio.com,https://app.seu-dominio.com
# SERVER_PORT=8000
